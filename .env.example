# Public Supabase configuration used by the Playbook frontend/Netlify Edge.
SUPABASE_URL=https://bryegtpdjqpwtyefoznq.supabase.co
SUPABASE_ANON_KEY=
PLAYBOOK_SUPABASE_URL=https://bryegtpdjqpwtyefoznq.supabase.co
PLAYBOOK_SUPABASE_PUBLISHABLE_KEY=

# Server-only key for Supabase Edge Functions.
# Never expose this value in HTML, JavaScript served to users, screenshots,
# docs, config/supabase.js, browser logs, or client-side bundles.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Zoho Desk sync/monitoring.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
ZOHO_DEPARTMENT_IDS=1128522000000453544,1128522000008788112,1128522000000006907

# Optional key used by cron to invoke sync-tickets-v0 when --fix is enabled.
# For Edge Functions with verify_jwt=true this must be a valid legacy JWT key
# accepted by the target Supabase project.
SYNC_FUNCTION_KEY=

# Optional monitor defaults.
MONITOR_OUTPUT_DIR=reports/parity
MONITOR_SINCE=
MONITOR_MAX_ZOHO_PAGES_PER_DEPARTMENT=500
MONITOR_MAX_FIX_TICKETS=200
MONITOR_COUNT_TOLERANCE=0
MONITOR_AUTH_TOKEN=
MONITOR_WEEKS=12
MONITOR_MONTHS=6
MONITOR_LOOKBACK_DAYS=90

# Initial admin bootstrap.
# The initial password must be stored as a Supabase Function secret, not in
# committed files. Use this example only as a variable-name reference.
PLAYBOOK_BOOTSTRAP_TOKEN=
PLAYBOOK_INITIAL_ADMIN_EMAIL=posvendas@alliage-global.com
PLAYBOOK_ADMIN_INITIAL_PASSWORD=
PLAYBOOK_BOOTSTRAP_RESET_PASSWORD=false
PLAYBOOK_ADMIN_FORCE_PASSWORD_CHANGE=false
